# Server Environment
NODE_ENV=production
PORT=3000
APP_URL=https://saferoute-api.yourdomain.com

# MongoDB Atlas Database URI
# Replace with your secure Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/saferoute?retryWrites=true&w=majority

# Security Keys
# Generate a secure random string (e.g., node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET_KEY=replace-this-with-a-very-secure-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Frontend CORS URL
ALLOWED_ORIGINS=https://saferoute.yourdomain.com

# Third-Party APIs
OPEN_ROUTER_KEY=your-open-router-key
AI_MODEL=mistralai/Mistral-7B-Instruct-v0.1

# Face Recognition
FACE_MATCH_THRESHOLD=0.6
